---
import LogoAnimated from './LogoAnimated.astro';
---

<section class="hero">
  <div class="container">
    <LogoAnimated />
    <p class="subtitle">Independent software from Turku, Finland</p>
  </div>
</section>

<style>
  .hero {
    min-height: 55vh;
    padding: 48px 24px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .subtitle {
    font-family: var(--font-sora), system-ui, sans-serif;
    font-weight: 400;
    font-size: 24px;
    color: var(--color-muted);
    margin-top: 1.5rem;
    text-align: center;
  }
</style>
