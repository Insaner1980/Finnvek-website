---
interface Props {
  name?: string;
}

const { name = 'KnitTools' } = Astro.props;
---

<article class="product">
  <p class="slabel product-label">
    <span class="dot" aria-hidden="true"></span>
    Featured product · <span class="num">01</span>
  </p>

  <h2 class="product-title">{name}</h2>

  <span class="title-rule" aria-hidden="true"></span>

  <p class="product-desc">
    A pocket companion for knitters. Counts your rows, reads your patterns,<br />and keeps your stash quietly in order. With <em>voice and AI that speaks knitter</em>.<br />In eleven languages.
  </p>

  <dl class="specs">
    <div class="spec">
      <dt>Platform</dt>
      <dd>Android 10+</dd>
    </div>
    <div class="spec">
      <dt>Languages</dt>
      <dd>11</dd>
    </div>
    <div class="spec">
      <dt>Status</dt>
      <dd>Coming soon</dd>
    </div>
  </dl>

  <div class="cta">
    <form class="waitlist" id="waitlist" novalidate>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="your.email@address"
        autocomplete="email"
        required
        aria-label="Email address"
      />
      <button type="submit">
        <span class="btn-text">Notify me at launch</span>
        <span class="arrow" aria-hidden="true">→</span>
      </button>
    </form>
    <a class="learn" href="https://knittoolsapp.com" target="_blank" rel="noopener">
      Learn more <span class="arrow">→</span> knittoolsapp.com
    </a>
  </div>
</article>

<style>
  .product {
    display: grid;
    gap: 24px;
    min-width: 0;
  }

  .product-label {
    margin-bottom: -8px;
  }

  .product-label .dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .title-rule {
    display: block;
    width: 80px;
    height: 1px;
    background: var(--color-border);
    margin-top: -8px;
    margin-bottom: -8px;
  }

  .product-title {
    font-family: var(--font-teko), 'Teko', sans-serif;
    font-weight: 500;
    font-size: clamp(48px, 7.5vw, 82px);
    line-height: 0.9;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .product-desc {
    font-family: 'Geist', system-ui, sans-serif;
    font-weight: 400;
    font-size: clamp(15px, 1.6vw, 17px);
    line-height: 1.7;
    color: var(--color-secondary);
    max-width: 56ch;
  }

  .product-desc em {
    font-style: normal;
    background: linear-gradient(transparent 62%, rgba(29, 180, 165, 0.18) 62%);
    padding: 0 2px;
  }

  .specs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--color-border);
    background: var(--bg-base);
    max-width: 56ch;
    width: 100%;
  }

  .specs .spec {
    padding: 18px 22px;
    border-right: 1px solid var(--color-border);
  }

  .specs .spec:last-child {
    border-right: none;
  }

  .specs dt {
    font-family: 'Routed Gothic', var(--font-dm-mono), monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 8px;
  }

  .specs dd {
    font-family: 'Routed Gothic', var(--font-dm-mono), monospace;
    font-weight: 400;
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.2;
    color: var(--color-secondary);
  }

  .cta {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
    margin-top: 12px;
  }

  .waitlist {
    display: flex;
    align-items: stretch;
    width: 100%;
    max-width: 460px;
    border: 1px solid var(--color-primary);
    background: var(--white);
  }

  .waitlist input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: var(--font-dm-mono), 'DM Mono', monospace;
    font-size: 13px;
    color: var(--color-primary);
    padding: 14px 16px;
    outline: none;
    letter-spacing: 0.04em;
    min-width: 0;
  }

  .waitlist input::placeholder {
    color: var(--color-dimmed);
    letter-spacing: 0.08em;
  }

  .waitlist button {
    position: relative;
    overflow: visible;
    border: none;
    background: var(--color-accent);
    color: var(--white);
    font-family: var(--font-dm-mono), 'DM Mono', monospace;
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0 24px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
    transition: background 0.15s ease, transform 140ms cubic-bezier(0.25, 0.8, 0.35, 1);
  }

  .waitlist button:hover {
    background: var(--color-accent-hover);
  }

  .waitlist button .arrow {
    display: inline-block;
    transition: transform 0.2s;
  }

  .waitlist button:hover .arrow {
    transform: translateX(3px);
  }

  .waitlist.pressed button {
    transform: scale(0.97);
  }

  .waitlist.ok button {
    background: var(--color-primary);
    color: var(--white);
  }

  .waitlist.ok button .arrow {
    display: none;
  }

  .learn {
    font-family: 'Routed Gothic', var(--font-dm-mono), monospace;
    font-size: 13px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-primary);
    padding-bottom: 6px;
    transition: color 0.15s, border-color 0.15s;
  }

  .learn:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .learn .arrow {
    color: var(--color-accent);
    margin: 0 4px;
  }

  @media (max-width: 720px) {
    .waitlist {
      max-width: none;
    }

    .specs {
      grid-template-columns: 1fr;
    }

    .specs .spec {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }

    .specs .spec:last-child {
      border-bottom: none;
    }
  }
</style>

<script>
  const WAITLIST_KEY = 'fv_waitlist_email';

  function markRestored(form: HTMLFormElement) {
    form.classList.add('ok');
    const input = form.querySelector('input') as HTMLInputElement | null;
    const btnText = form.querySelector('.btn-text') as HTMLElement | null;
    const button = form.querySelector('button') as HTMLButtonElement | null;
    if (input) input.disabled = true;
    if (btnText) btnText.textContent = "You're in!";
    if (button) button.disabled = true;
  }

  function animateSubmit(form: HTMLFormElement) {
    const input = form.querySelector('input') as HTMLInputElement | null;
    const btnText = form.querySelector('.btn-text') as HTMLElement | null;
    const button = form.querySelector('button') as HTMLButtonElement | null;

    if (input) input.disabled = true;
    if (button) button.disabled = true;

    form.classList.add('pressed');
    window.setTimeout(() => {
      form.classList.remove('pressed');
      form.classList.add('ok');
    }, 150);

    window.setTimeout(() => {
      if (btnText) btnText.textContent = "You're in!";
    }, 420);
  }

  document.querySelectorAll<HTMLFormElement>('.waitlist').forEach((form) => {
    const saved = localStorage.getItem(WAITLIST_KEY);
    const input = form.querySelector('input') as HTMLInputElement | null;

    if (saved) {
      if (input) input.value = saved;
      markRestored(form);
      return;
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = input?.value?.trim() ?? '';
      const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      const btnText = form.querySelector('.btn-text') as HTMLElement | null;

      if (!valid) {
        if (btnText) btnText.textContent = 'Check your email';
        input?.focus();
        return;
      }

      localStorage.setItem(WAITLIST_KEY, email);
      animateSubmit(form);
    });
  });
</script>
