<style>
  .logo-wrap {
    width: min(100%, 456px);
    position: relative;
    cursor: pointer;
  }

  .logo-svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .letter {
    opacity: 0;
    animation: letter-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .letter-f { animation-delay: 0.1s; }
  .letter-i { animation-delay: 0.2s; }
  .letter-n1 { animation-delay: 0.3s; }
  .letter-n2 { animation-delay: 0.4s; }
  .letter-v { animation-delay: 0.5s; }
  .letter-e { animation-delay: 0.6s; }
  .letter-k { animation-delay: 0.7s; }

  @keyframes letter-in {
    0% {
      opacity: 0;
      transform: translateY(15px) scale(0.8);
    }
    100% {
      opacity: 1;
      transform: none;
    }
  }

  /* F squishes when dot lands */
  .letter-f {
    animation: letter-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.1s forwards,
               squish-f 1.8s cubic-bezier(0.5, 0, 0.5, 1) 0.8s;
  }

  @keyframes squish-f {
    0%, 12% { transform: none; }
    16% { transform: scaleY(0.93) scaleX(1.03); transform-origin: center bottom; }
    22% { transform: none; }
  }

  /* E squishes when dot lands */
  .letter-e {
    animation: letter-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.6s forwards,
               squish-e 1.6s cubic-bezier(0.5, 0, 0.5, 1) 1.2s;
  }

  @keyframes squish-e {
    0%, 15% { transform: none; }
    19% { transform: scaleY(0.93) scaleX(1.03); transform-origin: center bottom; }
    25% { transform: none; }
  }

  /* Dot on F - bounces down from above */
  .dot-f {
    opacity: 0;
    animation: dot-f-bounce 1.8s cubic-bezier(0.5, 0, 0.5, 1) 0.8s forwards;
  }

  @keyframes dot-f-bounce {
    0% {
      opacity: 1;
      transform: translateY(-200px);
    }
    15% {
      transform: translateY(0);
    }
    25% {
      transform: translateY(-70px);
    }
    40% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-30px);
    }
    63% {
      transform: translateY(0);
    }
    72% {
      transform: translateY(-10px);
    }
    82% {
      transform: translateY(0);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Dot on E - bounces down slightly later */
  .dot-e {
    opacity: 0;
    animation: dot-e-bounce 1.6s cubic-bezier(0.5, 0, 0.5, 1) 1.2s forwards;
  }

  @keyframes dot-e-bounce {
    0% {
      opacity: 1;
      transform: translateY(-250px) translateX(30px);
    }
    18% {
      transform: translateY(0) translateX(0);
    }
    30% {
      transform: translateY(-55px);
    }
    45% {
      transform: translateY(0);
    }
    55% {
      transform: translateY(-20px);
    }
    68% {
      transform: translateY(0);
    }
    78% {
      transform: translateY(-6px);
    }
    88% {
      transform: translateY(0);
    }
    100% {
      opacity: 1;
      transform: none;
    }
  }

  /* Replay: strip all animations briefly */
  .logo-wrap.replay .letter,
  .logo-wrap.replay .dot-f,
  .logo-wrap.replay .dot-e {
    animation: none !important;
    opacity: 0 !important;
  }
</style>

<script>
  const wrap = document.getElementById('logoWrap');
  if (wrap) {
    wrap.addEventListener('click', () => {
      wrap.classList.add('replay');
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          wrap.classList.remove('replay');
        });
      });
    });
  }
</script>
