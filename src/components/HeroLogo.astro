---
import fs from 'node:fs';
import path from 'node:path';

const wordmarkPath = path.resolve('./public/finnvek-wordmark.svg');
const wordmarkSvg = fs.readFileSync(wordmarkPath, 'utf-8');
---

<div class="hero-logo" role="img" aria-label="Finnvek">
  <canvas id="finnvek-hero-canvas" aria-hidden="true"></canvas>
  <div id="finnvek-hero-fallback" class="hero-fallback" aria-hidden="true" set:html={wordmarkSvg}></div>
</div>

<script>
  const canvas = document.getElementById('finnvek-hero-canvas');
  const fallback = document.getElementById('finnvek-hero-fallback');

  if (canvas instanceof HTMLCanvasElement && fallback instanceof HTMLElement) {
    const revertToFallback = (): void => {
      canvas.style.display = 'none';
      fallback.style.display = '';
    };

    import('../scripts/hero-logo')
      .then(async ({ canRunHero, initHeroLogo }) => {
        if (!canRunHero(canvas)) return;

        // Optimistic swap — if init throws, revert.
        fallback.style.display = 'none';
        canvas.style.display = 'block';

        try {
          const scene = await initHeroLogo(canvas);
          if (!scene) revertToFallback();
        } catch (err) {
          console.error('[hero-logo] init failed:', err);
          revertToFallback();
        }
      })
      .catch((err) => {
        console.error('[hero-logo] chunk load failed:', err);
      });
  }
</script>

<style>
  .hero-logo {
    position: relative;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    display: block;
    overflow: hidden;
  }

  #finnvek-hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: none;
    opacity: 0;
  }

  .hero-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .hero-fallback :global(svg) {
    width: 100%;
    max-width: 600px;
    height: auto;
    display: block;
  }
</style>
