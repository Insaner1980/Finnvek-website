---
import LogoStatic from './LogoStatic.astro';
---

<footer class="footer">
  <div class="container">
    <a href="#" class="footer-logo-link"><LogoStatic /></a>
    <p class="footer-info">&copy; 2026 Finnvek &middot; <a href="mailto:contact@finnvek.com" class="footer-link">contact@finnvek.com</a> &middot; Turku, Finland</p>
  </div>
</footer>

<style>
  .footer {
    padding: 2.5rem 0 2rem;
    text-align: center;
  }

  .footer-logo-link {
    display: inline-block;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .footer-logo-link:hover {
    opacity: 1;
  }

  .footer-info {
    font-family: var(--font-dm-mono), monospace;
    font-size: 0.8rem;
    color: var(--color-muted);
    background: rgba(10, 10, 15, 0.85);
    padding: 10px 20px;
    border-radius: 8px;
    width: fit-content;
    margin: 0 auto;
  }

  .footer-link {
    color: inherit;
  }

  .footer-link:hover {
    color: var(--color-primary);
  }
</style>
