---
import BaseLayout from '../layouts/BaseLayout.astro';
import DbcheckLogo from '../assets/dbcheck-logo.svg';
---

<BaseLayout>
  <section class="hero">
    <div class="hero-meta">
      <div class="hero-meta-line1">Independent Software</div>
      <div class="hero-meta-line2">Turku, Finland<span class="hero-meta-time" data-local-time>.</span></div>
    </div>

    <a href="/" class="hero-wordmark" aria-label="Finnvek home">FINNVEK</a>

    <h1 class="hero-tagline">
      <span class="hero-tagline-line">Software made for <span class="years">years.</span></span>
      <span class="hero-tagline-line">Not weeks.</span>
    </h1>

    <div class="hero-scroll-cue" aria-hidden="true"></div>
  </section>

  <hr class="section-divider" data-section-line />

  <section class="about" data-about>
    <div class="section-label" data-about-line>About</div>
    <div class="about-body">
      <h2 data-about-line>Built around <span class="years">ideas</span> worth following.</h2>
      <p data-about-line>Finnvek is independent software from Turku, Finland. I'm one developer, working on my own projects.</p>
      <p data-about-line>It exists because some ideas were worth following, and I had the freedom to follow them. The kind of ideas that stay interesting for <span class="years">years</span>, not weeks. The kind I care about enough to build carefully, without shortcuts or rushed releases.</p>
      <p data-about-line>Every product is its own thing. No ads, no profiling, no data brokers. Made to work well, and to keep working for a long time.</p>
      <p data-about-line>The first three are KnitTools, runcheck, and dBcheck.</p>
      <div class="about-sig" data-about-line>Emma</div>
    </div>
  </section>

  <section class="product product--mirror" data-product>
    <div class="section-label" data-product-line>In the works</div>
    <div class="product-content">
      <a href="https://knittoolsapp.com" class="product-lockup" data-product-lockup aria-label="KnitTools — knittoolsapp.com">
        <img src="/images/knittools.webp" alt="" width="500" height="500" loading="lazy" decoding="async" data-product-logo data-logo-roll data-logo-stamp />
        <h2 class="product-name product-name--knittools">KnitTools</h2>
      </a>

      <div class="product-text">
        <p data-product-line>KnitTools is a pocket companion for knitters. It counts your rows, keeps your patterns one tap away, and your yarn, notes, and progress photos quietly in order. In eleven languages, for Android.</p>

        <form class="notify" data-notify-form data-product-line>
          <label class="visually-hidden" for="notify-email">Email address</label>
          <label class="visually-hidden" for="notify-website">Leave this field empty</label>
          <input
            class="visually-hidden"
            id="notify-website"
            name="website"
            type="text"
            tabindex="-1"
            autocomplete="off"
          />
          <input id="notify-email" name="email" type="email" placeholder="email address" autocomplete="email" required />
          <button type="submit">Notify me at launch</button>
        </form>
        <p class="notify-error" data-notify-error role="alert" aria-live="polite" hidden></p>

        <a href="https://knittoolsapp.com" class="product-link" data-product-line>knittoolsapp.com <span class="link-arrow">&rarr;</span></a>
      </div>
    </div>
  </section>

  <section class="product" data-product>
    <div class="section-label" aria-hidden="true"></div>
    <div class="product-content">
      <a href="https://runcheckapp.com" class="product-lockup" data-product-lockup aria-label="runcheck — runcheckapp.com">
        <img src="/images/runcheck.webp" alt="" width="1254" height="1254" loading="lazy" decoding="async" data-product-logo data-logo-rise data-logo-nudge />
        <h2 class="product-name product-name--runcheck">runcheck</h2>
      </a>

      <div class="product-text">
        <p data-product-line>runcheck shows your phone's real condition. It checks battery, network, thermals, and storage, and turns the raw numbers into one clear health score. It warns you before small problems become annoying ones. For Android.</p>

        <a href="https://runcheckapp.com" class="product-link" data-product-line>runcheckapp.com <span class="link-arrow">&rarr;</span></a>
      </div>
    </div>
  </section>

  <section class="product product--mirror" data-product>
    <div class="section-label" aria-hidden="true"></div>
    <div class="product-content">
      <a href="https://dbcheck.app" class="product-lockup" data-product-lockup aria-label="dBcheck — dbcheck.app">
        <DbcheckLogo aria-hidden="true" focusable="false" data-product-logo data-logo-signal />
        <h2 class="product-name product-name--dbcheck">dB<em>check</em></h2>
      </a>

      <div class="product-text">
        <p data-product-line>dBcheck makes everyday sound easier to understand. It helps you follow noise exposure over time and compare personal hearing checks with your own baseline. For Android.</p>

        <a href="https://dbcheck.app" class="product-link" data-product-line>dbcheck.app <span class="link-arrow">&rarr;</span></a>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <div class="footer-wordmark">FINNVEK</div>
        <div class="footer-tagline">built to last</div>
      </div>
      <div class="footer-meta">
        <a href="mailto:contact@finnvek.com">Contact</a>
        <a href="/privacy">Privacy Policy</a>
        <span>&copy; 2026</span>
      </div>
    </div>
  </footer>
</BaseLayout>

<script>
  import '../scripts/home-animations';
</script>
