---
import LogoAnimated from './LogoAnimated.astro';
---

<div class="hero-logo" id="heroLogo">
  <LogoAnimated />
</div>

<style>
  .hero-logo {
    position: fixed;
    width: 98.9vh;
    left: 0;
    top: 0.3vh;
    transform-origin: top left;
    transform: rotate(-90deg) translateX(-100%);
    z-index: 10;
  }

  @media (max-width: 720px) {
    .hero-logo {
      position: relative;
      width: calc(100% - 2rem);
      left: auto;
      top: auto;
      transform: none;
      transform-origin: initial;
      margin: 1.5rem auto 0;
      padding: 0;
    }
  }
</style>
