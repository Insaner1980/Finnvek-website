---
const labels = Array.from({ length: 21 }, (_, i) => i * 100);
---

<div class="ruler" aria-hidden="true">
  <div class="ruler-minor"></div>
  <div class="ruler-major"></div>
  <div class="ruler-labels">
    {labels.map((n) => (
      <span class="ruler-num" style={`top: ${n}px`}>{n}</span>
    ))}
  </div>
  <span class="ruler-unit">mm</span>
</div>

<style>
  .ruler {
    position: fixed;
    top: 56px;
    bottom: 16px;
    left: 16px;
    width: 96px;
    overflow: hidden;
    pointer-events: none;
    z-index: 2;
  }

  .ruler-minor,
  .ruler-major {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
  }

  .ruler-minor {
    width: 8px;
    background-image: repeating-linear-gradient(
      to bottom,
      var(--color-border) 0 1px,
      transparent 1px 10px
    );
  }

  .ruler-major {
    width: 16px;
    background-image: repeating-linear-gradient(
      to bottom,
      var(--color-muted) 0 1px,
      transparent 1px 50px
    );
  }

  .ruler-labels {
    position: absolute;
    inset: 0;
  }

  .ruler-num {
    position: absolute;
    right: 22px;
    transform: translateY(-50%);
    font-family: 'Routed Gothic', var(--font-dm-mono), monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    line-height: 1;
  }

  .ruler-unit {
    position: absolute;
    right: 22px;
    bottom: 6px;
    font-family: 'Routed Gothic', var(--font-dm-mono), monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  @media (max-width: 720px) {
    .ruler {
      display: none;
    }
  }
</style>
